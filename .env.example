# LLM API Configuration (supports any LLM API in OpenAI SDK format)
# Recommended: Use Alibaba Bailian platform qwen-plus model: https://bailian.console.aliyun.com/
# Note: High token consumption. Try with less than 40 rounds first.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=your_base_url_here
LLM_MODEL_NAME=your_model_name_here

# ===== Accelerated LLM Configuration (Optional)=====
# Note: If not using accelerated config, do not include the following items in .env
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Demand Sensing Configuration =====
# Enable demand sensing module
DEMAND_SENSING_ENABLED=false
# Signal sources to fetch (comma-separated): pos, weather, inventory, promotion, event
DEMAND_SIGNAL_SOURCES=pos,weather,inventory,promotion
# Deviation threshold for triggering adjustments (percentage)
DEMAND_DEVIATION_THRESHOLD=15.0
# Number of days to forecast
DEMAND_FORECAST_DAYS=14
# Forecasting model: prophet (requires: pip install prophet)
# Falls back to simple day-of-week average if not installed

# ===== External APIs for Demand Signals =====
# ERP API for POS and inventory data
ERP_API_URL=http://localhost:8080/api
ERP_API_KEY=your_erp_api_key
# OpenWeatherMap API for weather data
WEATHER_API_KEY=your_openweathermap_api_key