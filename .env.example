# LLM API Configuration (supports any LLM API in OpenAI SDK format)
# Recommended: Use Alibaba Bailian platform qwen-plus model: https://bailian.console.aliyun.com/
# Note: High token consumption. Try with less than 40 rounds first.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=your_base_url_here
LLM_MODEL_NAME=your_model_name_here

# ===== ZEP Memory Graph Configuration =====
# Free monthly quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM Configuration (Optional)=====
# Note: If not using accelerated config, do not include the following items in .env
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here